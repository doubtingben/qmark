def main() -> int:
    parser = argparse.ArgumentParser(
        prog="qmark",
        description="Ask a quick terminal syntax question using Ollama or an OpenAI-compatible API.",
    )
    parser.add_argument("prompt", nargs="*", help="Short natural-language question.")
    parser.add_argument(
        "--provider",
        choices=["ollama", "openai", "openai-compatible", "openrouter", "remote"],
        default=DEFAULT_PROVIDER,
        help=f"Model provider. Default: {DEFAULT_PROVIDER}",
    )
    parser.add_argument(
        "-m",
        "--model",
        default=DEFAULT_MODEL,
        help=(
            "Model name. Defaults to QMARK_MODEL if set, otherwise "
            f"{DEFAULT_OLLAMA_MODEL} for Ollama or {DEFAULT_REMOTE_MODEL} for remote providers."
        ),
    )
    parser.add_argument("--host", help="Ollama host or OpenAI-compatible base URL. Defaults depend on --provider.")
    parser.add_argument("--api-key", default=os.environ.get("QMARK_API_KEY"), help="API key for remote providers.")
    parser.add_argument(
        "--namespace",
        default=DEFAULT_NAMESPACE,
        help="Model namespace for remote providers, for example z-ai. Default: QMARK_NAMESPACE.",
    )
    parser.add_argument("--cmd", action="store_true", help="Print only the primary command.")
    parser.add_argument("--copy", action="store_true", help="Copy the primary command to the clipboard with pbcopy.")
    parser.add_argument("--json", action="store_true", help="Print the parsed JSON response.")
    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Print explanation, alternatives, requirements, notes, risk, and confidence.",
    )
    parser.add_argument("--run", action="store_true", help="Ask for confirmation, then run the primary command.")
    parser.add_argument("--unsafe", action="store_true", help="Allow --run for high-risk commands after confirmation.")
    parser.add_argument("--no-status", action="store_true", help="Do not show an interactive model wait indicator.")
    parser.add_argument("--no-context", action="store_true", help="Do not include cwd/git/file context.")
    parser.add_argument("--history-lines", type=int, default=0, help="Opt-in: include this many recent shell history lines.")
    parser.add_argument("--learn", metavar="NAME", help="Read help/docs from stdin and save them as local knowledge.")
    parser.add_argument("--learn-command", metavar="NAME", help="Run the remaining prompt as a command and save its output.")
    parser.add_argument("--list-knowledge", action="store_true", help="List saved local knowledge names.")
    parser.add_argument("--show-context", action="store_true", help="Print gathered context and exit without calling the model.")
    parser.add_argument("--knowledge-dir", default=str(DEFAULT_HOME / "knowledge"), help="Directory for saved local knowledge.")
    parser.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")
    args = parser.parse_args()
    try:
        provider = normalize_provider(args.provider)
    except ValueError as exc:
        parser.error(str(exc))
    if provider == "ollama":
        host = args.host or DEFAULT_OLLAMA_HOST
        model = args.model or DEFAULT_OLLAMA_MODEL
    else:
        host = args.host or DEFAULT_OPENAI_BASE_URL
        model = resolve_remote_model(args.model or DEFAULT_REMOTE_MODEL, args.namespace)

    knowledge_dir = Path(args.knowledge_dir).expanduser()
    if args.list_knowledge:
        return list_knowledge(knowledge_dir)
    if args.learn:
        text = sys.stdin.read()
        return save_knowledge(knowledge_dir, args.learn, text, source="stdin")
    if args.learn_command:
        if not args.prompt:
            print("qmark: --learn-command needs a command after the name.", file=sys.stderr)
            return 2
        text = capture_command(args.prompt)
        return save_knowledge(knowledge_dir, args.learn_command, text, source=" ".join(args.prompt))

    question = " ".join(args.prompt).strip()
    if not question:
        parser.print_help(sys.stderr)
        return 2

    context = "" if args.no_context else build_context(args.history_lines, question)
    knowledge = retrieve_knowledge(knowledge_dir, question)
    if knowledge:
        context = f"{context}\n\nlocal_knowledge:\n{knowledge}" if context else f"local_knowledge:\n{knowledge}"
    if args.show_context:
        print(context)
        return 0
    try:
        result = ask_model_with_status(
            provider,
            host,
            model,
            args.api_key,
            question,
            context,
            enabled=not args.no_status,
        )
    except RuntimeError as exc:
        print(f"qmark: {exc}", file=sys.stderr)
        return 1

    result["risk"] = combined_risk(result.get("risk", "low"), result.get("command", ""))

    if args.json:
        print(json.dumps(result, indent=2))
    elif args.cmd:
        print(result.get("command", "").strip())
    elif not args.verbose and should_print_command_only(result):
        print(result.get("command", "").strip())
    else:
        print_human(result)

    command = result.get("command", "").strip()
    if args.copy and command:
        copy_to_clipboard(command)
    if args.run:
        return run_after_confirm(command, result.get("risk", "low"), args.unsafe)
    return 0


def ollama_api_url(host: str) -> str:
    host = host.rstrip("/")
    if host.endswith("/api"):
        return f"{host}/chat"
    return f"{host}/api/chat"


def chat_completions_url(base_url: str) -> str:
    base_url = base_url.rstrip("/")
    if base_url.endswith("/chat/completions"):
        return base_url
    return f"{base_url}/chat/completions"


def ask_model(provider: str, host: str, model: str, api_key: str | None, question: str, context: str) -> dict[str, Any]:
    system, user = build_messages(question, context)
    if provider == "ollama":
        return ask_ollama(host, model, system, user)
    if provider == "openai":
        return ask_openai_compatible(host, model, api_key, system, user)
    raise RuntimeError(f"unknown provider: {provider}")


def ask_model_with_status(
    provider: str,
    host: str,
    model: str,
    api_key: str | None,
    question: str,
    context: str,
    enabled: bool,
) -> dict[str, Any]:
    if not should_show_status(enabled):
        return ask_model(provider, host, model, api_key, question, context)

    status = QueryStatus(provider, model)
    status.start()
    try:
        result = ask_model(provider, host, model, api_key, question, context)
    except BaseException:
        status.stop(success=False)
        raise
    finally:
        if not status.done.is_set():
            status.stop(success=True)
    return result


def should_show_status(enabled: bool) -> bool:
    if not enabled:
        return False
    if os.environ.get("QMARK_NO_STATUS"):
        return False
    return sys.stderr.isatty()


def format_elapsed(seconds: float) -> str:
    if seconds < 60:
        return f"{seconds:.1f}s"
    minutes, remainder = divmod(int(seconds), 60)
    return f"{minutes}m {remainder:02d}s"


def terminal_line_width() -> int:
    return max(20, shutil.get_terminal_size((100, 20)).columns - 1)


class QueryStatus:
    def __init__(self, provider: str, model: str) -> None:
        self.provider = provider
        self.model = model
        self.started = time.monotonic()
        self.done = threading.Event()
        self.thread = threading.Thread(target=self._run, daemon=True)

    def start(self) -> None:
        self.thread.start()

    def stop(self, success: bool) -> None:
        self.done.set()
        self.thread.join(timeout=0.5)
        elapsed = time.monotonic() - self.started
        verb = "response received" if success else "request failed"
        self._write_line(f"qmark: {verb} in {format_elapsed(elapsed)}", newline=True)

    def _run(self) -> None:
        for frame in itertools.cycle("|/-\\"):
            elapsed = time.monotonic() - self.started
            message = (
                f"qmark: waiting for {self.provider}/{self.model} "
                f"{frame} {format_elapsed(elapsed)}"
            )
            self._write_line(message, newline=False)
            if self.done.wait(0.1):
                return

    def _write_line(self, message: str, newline: bool) -> None:
        width = terminal_line_width()
        sys.stderr.write("\r" + message[:width].ljust(width))
        if newline:
            sys.stderr.write("\n")
        sys.stderr.flush()


def normalize_provider(value: str) -> str:
    normalized = value.strip().lower()
    if normalized == "ollama":
        return "ollama"
    if normalized in {"openai", "openai-compatible", "openrouter", "remote"}:
        return "openai"
    raise ValueError(f"unknown provider: {value}")


def resolve_remote_model(model: str, namespace: str | None) -> str:
    namespace = (namespace or "").strip().strip("/")
    model = model.strip()
    if namespace and "/" not in model:
        return f"{namespace}/{model}"
    return model


def build_messages(question: str, context: str) -> tuple[str, str]:
    system = (
        "You are a terse terminal syntax assistant. The user is in a shell session and "
        "typed a short prompt after a question-mark helper command. Return only JSON "
        "with this shape: answer string, command string, alternatives string array, "
        "requires string array, risk one of low/medium/high, confidence one of "
        "low/medium/high, notes string array. Use confidence high only when the "
        "command syntax directly matches the request and context. Give one best "
        "command when possible. Keep explanations short. Prefer safe, inspectable "
        "commands. If a command may change files, use dry-run/listing flags when "
        "available and mark risk medium or high."
    )
    user = f"Question:\n{question}\n\nContext:\n{context or '(context disabled)'}"
    return system, user


def ask_ollama(host: str, model: str, system: str, user: str) -> dict[str, Any]:
    payload: dict[str, Any] = {
        "model": model,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user", "content": user},
        ],
        "stream": False,
        "format": SCHEMA,
        "options": {"temperature": 0.1},
    }
    data = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(
        ollama_api_url(host),
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=90) as resp:
            raw = json.loads(resp.read().decode("utf-8"))
    except urllib.error.URLError as exc:
        raise RuntimeError(
            f"could not reach Ollama at {host}. Start it with `ollama serve` "
            "or set OLLAMA_HOST."
        ) from exc
    except TimeoutError as exc:
        raise RuntimeError("Ollama request timed out.") from exc

    content = raw.get("message", {}).get("content", "") or ""
    parsed = parse_model_json(content)
    return normalize_result(parsed)


def ask_openai_compatible(
    base_url: str,
    model: str,
    api_key: str | None,
    system: str,
    user: str,
) -> dict[str, Any]:
    api_key = api_key or infer_api_key(base_url)
    if not api_key:
        raise RuntimeError(
            "missing API key for remote provider. Set QMARK_API_KEY, OPENROUTER_API_KEY, "
            "or OPENAI_API_KEY, or pass --api-key."
        )
    payload = {
        "model": model,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user", "content": user},
        ],
        "temperature": 0.1,
        "response_format": {"type": "json_object"},
    }
    headers = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
    }
    referer = os.environ.get("QMARK_HTTP_REFERER")
    app_title = os.environ.get("QMARK_APP_TITLE", "qmark")
    if referer:
        headers["HTTP-Referer"] = referer
    if app_title:
        headers["X-Title"] = app_title

    raw = post_chat_completions(base_url, headers, payload)

    content = raw.get("choices", [{}])[0].get("message", {}).get("content", "") or ""
    parsed = parse_model_json(content)
    return normalize_result(parsed)


def parse_model_json(content: str) -> dict[str, Any]:
    try:
        parsed = json.loads(content)
    except json.JSONDecodeError as exc:
        fenced = re.fullmatch(r"\s*```(?:json)?\s*(.*?)\s*```\s*", content, flags=re.DOTALL | re.IGNORECASE)
        if fenced:
            try:
                parsed = json.loads(fenced.group(1))
            except json.JSONDecodeError:
                raise RuntimeError(f"model returned invalid JSON: {content[:300]!r}") from exc
        else:
            raise RuntimeError(f"model returned invalid JSON: {content[:300]!r}") from exc
    if not isinstance(parsed, dict):
        raise RuntimeError(f"model returned JSON that is not an object: {content[:300]!r}")
    return parsed


def post_chat_completions(base_url: str, headers: dict[str, str], payload: dict[str, Any]) -> dict[str, Any]:
    url = chat_completions_url(base_url)
    try:
        return post_json(url, headers, payload)
    except urllib.error.HTTPError as exc:
        detail = exc.read().decode("utf-8", errors="replace")[:500]
        if exc.code == 400 and "response_format" in detail and "response_format" in payload:
            retry_payload = dict(payload)
            retry_payload.pop("response_format")
            try:
                return post_json(url, headers, retry_payload)
            except urllib.error.HTTPError as retry_exc:
                retry_detail = retry_exc.read().decode("utf-8", errors="replace")[:500]
                raise RuntimeError(
                    f"remote API request failed with HTTP {retry_exc.code}: {retry_detail}"
                ) from retry_exc
            except urllib.error.URLError as retry_exc:
                raise RuntimeError(f"could not reach remote API at {base_url}.") from retry_exc
            except TimeoutError as retry_exc:
                raise RuntimeError("remote API request timed out.") from retry_exc
        raise RuntimeError(f"remote API request failed with HTTP {exc.code}: {detail}") from exc
    except urllib.error.URLError as exc:
        raise RuntimeError(f"could not reach remote API at {base_url}.") from exc
    except TimeoutError as exc:
        raise RuntimeError("remote API request timed out.") from exc


def post_json(url: str, headers: dict[str, str], payload: dict[str, Any]) -> dict[str, Any]:
    data = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(url, data=data, headers=headers, method="POST")
    with urllib.request.urlopen(req, timeout=90) as resp:
        return json.loads(resp.read().decode("utf-8"))


def infer_api_key(base_url: str) -> str | None:
    if "openrouter.ai" in base_url:
        return os.environ.get("OPENROUTER_API_KEY") or os.environ.get("OPENAI_API_KEY")
    return os.environ.get("OPENAI_API_KEY")


def normalize_result(value: dict[str, Any]) -> dict[str, Any]:
    return {
        "answer": str(value.get("answer", "")).strip(),
        "command": str(value.get("command", "")).strip(),
        "alternatives": list_of_strings(value.get("alternatives", []))[:3],
        "requires": list_of_strings(value.get("requires", []))[:5],
        "risk": str(value.get("risk", "low")).strip().lower(),
        "confidence": normalize_confidence(value.get("confidence", "medium")),
        "notes": list_of_strings(value.get("notes", []))[:5],
    }


def normalize_confidence(value: Any) -> str:
    confidence = str(value).strip().lower()
    if confidence in {"low", "medium", "high"}:
        return confidence
    return "medium"


def list_of_strings(value: Any) -> list[str]:
    if not isinstance(value, list):
        return []
    return [str(item).strip() for item in value if str(item).strip()]


def build_context(history_lines: int, question: str = "") -> str:
    lines = [
        f"os: {platform.platform()}",
        f"shell: {os.environ.get('SHELL', 'unknown')}",
        f"cwd: {Path.cwd()}",
    ]
    root = git_root()
    lines.extend(git_context(root))
    if root:
        lines.extend(repo_context(root, question))
    lines.extend(file_context())
    if history_lines > 0:
        lines.extend(history_context(history_lines))
    return "\n".join(lines)


def capture_command(command: list[str]) -> str:
    try:
        proc = subprocess.run(command, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=30)
    except FileNotFoundError:
        print(f"qmark: command not found: {command[0]}", file=sys.stderr)
        raise SystemExit(127)
    except subprocess.TimeoutExpired:
        print("qmark: help command timed out.", file=sys.stderr)
        raise SystemExit(124)
    output = proc.stdout
    if proc.stderr:
        output += "\n[stderr]\n" + proc.stderr
    return output


def save_knowledge(knowledge_dir: Path, name: str, text: str, source: str) -> int:
    body = redact(text).strip()
    if not body:
        print("qmark: no knowledge text to save.", file=sys.stderr)
        return 1
    knowledge_dir.mkdir(parents=True, exist_ok=True)
    path = knowledge_dir / f"{safe_name(name)}.txt"
    existing = path.read_text(errors="ignore") if path.exists() else ""
    entry = (
        f"\n\n---\n"
        f"name: {name}\n"
        f"source: {source}\n"
        f"cwd: {Path.cwd()}\n"
        f"---\n\n"
        f"{body}\n"
    )
    path.write_text((existing.rstrip() + entry).lstrip(), encoding="utf-8")
    print(f"Saved knowledge: {path}")
    return 0


def list_knowledge(knowledge_dir: Path) -> int:
    if not knowledge_dir.exists():
        print("No saved knowledge.")
        return 0
    names = sorted(path.stem for path in knowledge_dir.glob("*.txt"))
    if not names:
        print("No saved knowledge.")
        return 0
    for name in names:
        print(name)
    return 0


def retrieve_knowledge(knowledge_dir: Path, question: str) -> str:
    if not knowledge_dir.exists():
        return ""
    query_tokens = tokens(question)
    if not query_tokens:
        return ""

    scored: list[tuple[int, str, str]] = []
    for path in knowledge_dir.glob("*.txt"):
        try:
            text = path.read_text(errors="ignore")
        except OSError:
            continue
        for chunk in chunks(text):
            score = score_chunk(query_tokens, chunk)
            if score > 0:
                scored.append((score, path.stem, chunk))

    selected: list[str] = []
    used = 0
    for _, name, chunk in sorted(scored, reverse=True)[:8]:
        excerpt = chunk.strip()
        room = MAX_KNOWLEDGE_CHARS - used
        if room <= 0:
            break
        if len(excerpt) > room:
            excerpt = excerpt[:room].rsplit("\n", 1)[0].strip()
        selected.append(f"[{name}]\n{excerpt}")
        used += len(excerpt)
    return "\n\n".join(selected)


def chunks(text: str) -> list[str]:
    sections = re.split(r"\n(?=\S)|\n{2,}", text)
    result = []
    current = ""
    for section in sections:
        section = section.strip()
        if not section:
            continue
        if len(current) + len(section) + 2 <= 1200:
            current = f"{current}\n\n{section}".strip()
        else:
            if current:
                result.append(current)
            current = section[:2000]
    if current:
        result.append(current)
    return result


def score_chunk(query_tokens: set[str], chunk: str) -> int:
    chunk_tokens = tokens(chunk)
    overlap = query_tokens & chunk_tokens
    score = len(overlap) * 4
    lowered = chunk.lower()
    for token in query_tokens:
        if f"--{token}" in lowered or f"-{token}" in lowered:
            score += 6
    return score


def tokens(text: str) -> set[str]:
    return {
        token.lower()
        for token in re.findall(r"[a-zA-Z0-9][a-zA-Z0-9_.:-]{1,}", text)
        if token.lower() not in {"the", "and", "for", "with", "that", "this", "from", "into"}
    }


def safe_name(name: str) -> str:
    cleaned = re.sub(r"[^a-zA-Z0-9_.-]+", "-", name.strip()).strip("-")
    return cleaned or "knowledge"


def git_root() -> Path | None:
    if not shutil.which("git"):
        return None
    root = run_capture(["git", "rev-parse", "--show-toplevel"])
    if not root:
        return None
    return Path(root)


def git_context(root: Path | None) -> list[str]:
    if not root:
        return []
    branch = run_capture(["git", "-C", str(root), "branch", "--show-current"])
    status = run_capture(["git", "-C", str(root), "status", "--short"])
    lines = [f"git_root: {root}"]
    relative_cwd = relative_to(Path.cwd(), root)
    if relative_cwd and relative_cwd != ".":
        lines.append(f"git_relative_cwd: {relative_cwd}")
    if branch:
        lines.append(f"git_branch: {branch}")
    if status:
        lines.append("git_status:")
        lines.extend(f"  {line}" for line in status.splitlines()[:20])
    return lines


def repo_context(root: Path, question: str) -> list[str]:
    tracked = tracked_files(root)
    if not tracked:
        return []

    lines = [
        f"repo_tracked_files: {len(tracked)}",
    ]
    top_level = top_level_entries(tracked)
    if top_level:
        lines.append("repo_top_level: " + ", ".join(top_level[:40]))
    file_types = file_type_summary(tracked)
    if file_types:
        lines.append("repo_file_types: " + ", ".join(file_types))

    sample = file_sample(tracked, question)
    if sample:
        lines.append("repo_files_sample:")
        lines.extend(f"  {path}" for path in sample[:MAX_REPO_FILE_SAMPLE])

    selected = select_repo_context_files(tracked, question)
    if not selected:
        return lines

    lines.append("repo_context_files:")
    used = len("\n".join(lines))
    for rel_path in selected:
        entry = repo_file_excerpt(root, rel_path)
        if not entry:
            continue
        if used + len(entry) + 1 > MAX_REPO_CONTEXT_CHARS:
            break
        lines.extend(entry.splitlines())
        used += len(entry) + 1
    return lines


def tracked_files(root: Path) -> list[str]:
    output = run_capture(["git", "-C", str(root), "ls-files"])
    if not output:
        return []
    return [line for line in output.splitlines() if line]


def relative_to(path: Path, root: Path) -> str | None:
    try:
        return str(path.resolve().relative_to(root.resolve())) or "."
    except (OSError, ValueError):
        return None


def top_level_entries(paths: list[str]) -> list[str]:
    entries = {path.split("/", 1)[0] + ("/" if "/" in path else "") for path in paths}
    return sorted(entries, key=lambda value: value.lower())


def file_type_summary(paths: list[str]) -> list[str]:
    counts: dict[str, int] = {}
    for path in paths:
        suffix = Path(path).suffix.lower()
        label = suffix if suffix else "[no extension]"
        counts[label] = counts.get(label, 0) + 1
    return [
        f"{label}:{count}"
        for label, count in sorted(counts.items(), key=lambda item: (-item[1], item[0]))[:10]
    ]


def file_sample(paths: list[str], question: str) -> list[str]:
    query = tokens(question)
    return sorted(paths, key=lambda path: file_priority(path, query))[:MAX_REPO_FILE_SAMPLE]


def select_repo_context_files(paths: list[str], question: str) -> list[str]:
    query = tokens(question)
    scored = [(file_priority(path, query), path) for path in paths]
    selected = [path for (score, _), path in sorted(scored) if score < 1000]
    return selected[:MAX_REPO_CONTEXT_FILES]


def file_priority(path: str, query: set[str]) -> tuple[int, str]:
    path_obj = Path(path)
    name = path_obj.name
    name_lower = name.lower()
    path_lower = path.lower()
    score = 1000

    if name_lower in PROJECT_FILE_NAME_KEYS or any(
        name_lower.endswith(suffix) for suffix in PROJECT_FILE_SUFFIXES
    ):
        score = min(score, 10)
    if name_lower.startswith("readme"):
        score = min(score, 15)
    if query and any(token in path_lower for token in query):
        score = min(score, 20)
    score += path.count("/") * 5
    return (score, path_lower)


def repo_file_excerpt(root: Path, rel_path: str) -> str:
    path = root / rel_path
    if Path(rel_path).name.lower() in LOCK_FILE_NAME_KEYS:
        return f"  [{rel_path}]\n    present; lockfile contents omitted"
    try:
        if not path.is_file():
            return ""
        raw = path.read_bytes()
    except OSError:
        return ""
    if b"\0" in raw:
        return f"  [{rel_path}]\n    binary file omitted"

    text = redact(raw.decode("utf-8", errors="ignore")).strip()
    if not text:
        return ""
    if len(text) > MAX_REPO_FILE_EXCERPT_CHARS:
        text = text[:MAX_REPO_FILE_EXCERPT_CHARS].rsplit("\n", 1)[0].rstrip()
        text = f"{text}\n    ... truncated"
    indented = "\n".join(f"    {line}" if line else "" for line in text.splitlines())
    return f"  [{rel_path}]\n{indented}"


def file_context() -> list[str]:
    try:
        names = sorted(Path.cwd().iterdir(), key=lambda path: path.name.lower())
    except OSError:
        return []
    visible = []
    for path in names:
        name = path.name + ("/" if path.is_dir() else "")
        if name in {".git/", "__pycache__/"}:
            continue
        visible.append(name)
        if len(visible) >= 40:
            break
    return ["cwd_entries: " + ", ".join(visible)] if visible else []


def history_context(count: int) -> list[str]:
    histfile = os.environ.get("HISTFILE")
    if not histfile:
        return []
    try:
        lines = Path(histfile).expanduser().read_text(errors="ignore").splitlines()
    except OSError:
        return []
    recent = [redact(line) for line in lines[-count:]]
    return ["recent_history:"] + [f"  {line}" for line in recent]


def redact(text: str) -> str:
    redacted = text
    for pattern, replacement in SECRET_PATTERNS:
        redacted = pattern.sub(replacement, redacted)
    return redacted


def run_capture(command: list[str]) -> str | None:
    try:
        proc = subprocess.run(command, text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, timeout=2)
    except (OSError, subprocess.SubprocessError):
        return None
    if proc.returncode != 0:
        return None
    return proc.stdout.strip()


def combined_risk(model_risk: str, command: str) -> str:
    if is_risky(command):
        return "high"
    if model_risk in {"low", "medium", "high"}:
        return model_risk
    return "low"


def is_risky(command: str) -> bool:
    return any(re.search(pattern, command) for pattern in RISKY_PATTERNS)


def should_print_command_only(result: dict[str, Any]) -> bool:
    return (
        bool(result.get("command", "").strip())
        and result.get("confidence") == "high"
        and result.get("risk") != "high"
    )


def print_human(result: dict[str, Any]) -> None:
    answer = result.get("answer", "")
    command = result.get("command", "")
    print(textwrap.fill(answer, width=88) if answer else "No explanation returned.")
    if command:
        print("\nCommand:")
        print(f"  {command}")
    if result.get("alternatives"):
        print("\nAlternatives:")
        for item in result["alternatives"]:
            print(f"  - {item}")
    if result.get("requires"):
        print("\nRequires:")
        for item in result["requires"]:
            print(f"  - {item}")
    if result.get("notes"):
        print("\nNotes:")
        for item in result["notes"]:
            print(f"  - {item}")
    print(f"\nRisk: {result.get('risk', 'low')}")
    print(f"Confidence: {result.get('confidence', 'medium')}")


def copy_to_clipboard(command: str) -> None:
    if not shutil.which("pbcopy"):
        print("qmark: pbcopy not found; command was not copied.", file=sys.stderr)
        return
    subprocess.run(["pbcopy"], input=command, text=True, check=False)
    print("Copied command to clipboard.", file=sys.stderr)


def run_after_confirm(command: str, risk: str, unsafe: bool) -> int:
    if not command:
        print("qmark: no command to run.", file=sys.stderr)
        return 1
    if risk == "high" and not unsafe:
        print("qmark: refusing to run a high-risk command without --unsafe.", file=sys.stderr)
        return 1
    reply = input(f"Run this {risk}-risk command? [y/N]\n{command}\n> ").strip().lower()
    if reply not in {"y", "yes"}:
        print("Cancelled.", file=sys.stderr)
        return 130
    shell = os.environ.get("SHELL") or "/bin/sh"
    return subprocess.run(command, shell=True, executable=shell).returncode


